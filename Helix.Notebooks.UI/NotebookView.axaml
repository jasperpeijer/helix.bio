<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Helix.Notebooks.Core;assembly=Helix.Notebooks.Core"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             x:Class="Helix.Notebooks.UI.NotebookView"
             x:DataType="core:NotebookSession"
             x:CompileBindings="False"
             Background="#F8FAFC">
    
    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="+ Python Cell" Command="{Binding AddPythonCellCommand}" Background="#E0F2FE" Foreground="#0369A1" FontWeight="SemiBold" CornerRadius="4" />
                <Button Content="+ Markdown Cell" Command="{Binding AddMarkdownCellCommand}" Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold" CornerRadius="4" />
                <Border Width="1" Background="#E2E8F0" Margin="4,0"/>
                <Button Content="Run All Cells" Command="{Binding RunAllCellsCommand}" Background="#10B981" Foreground="#FFFFFF" FontWeight="SemiBold" CornerRadius="4" />
                <Border Width="1" Background="#E2E8F0" Margin="4,0"/>
            </StackPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Cells}" Margin="24">
                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="core:PythonCodeCell">
                        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                            <StackPanel Grid.Column="0" Width="60" Margin="0,12,8,0">
                                <TextBlock Text="[ Python ]" Foreground="#3B82F6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" />
                            </StackPanel>
                            
                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                                <Grid RowDefinitions="Auto, Auto, Auto">
                                    <!-- Input Text Box -->
                                    <!-- ReSharper disable once Xaml.InvalidType -->
                                    <TextBox Grid.Row="0" Text="{Binding SourceText}" AcceptsReturn="True" MinLines="3" FontFamily="Consolas, monospace" Background="#F8FAFC" BorderThickness="0" Padding="12"/>
                                    
                                    <!-- Action Bar (Individual Run Button) -->
                                    <Border Grid.Row="1" Background="#F1F5F9" Padding="8,4">
                                        <Button Content="▶ Run Cell" Command="{Binding $parent[UserControl].((core:NotebookSession)DataContext).RunSingleCellCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="#64748B" FontSize="12" Padding="4" />
                                    </Border>
                                    
                                    <!-- Output Terminal (Only visible if the cell has output) -->
                                    <Border Grid.Row="2" Background="#1E293B" Padding="12" IsVisible="{Binding OutputText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding OutputText}" Foreground="#10B981" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                    
                    <DataTemplate DataType="core:MarkdownCell">
                        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                            <StackPanel Grid.Column="0" Width="60" Margin="0,12,8,0">
                                <TextBlock Text="[ Text ]" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" />
                            </StackPanel>
                            
                            <Border Grid.Column="1" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12">
                                <Grid>
                                    <!-- ===================== EDIT MODE ===================== -->
                                    <StackPanel IsVisible="{Binding IsEditing}">
                                        <TextBox Text="{Binding SourceText}" AcceptsReturn="True" MinLines="2" Background="#FFFFFF" BorderBrush="#E2E8F0" Padding="8" />
                                        <Button Content="✓ Render Markdown" 
                                                Command="{Binding $parent[UserControl].((core:NotebookSession)DataContext).RunSingleCellCommand}" 
                                                CommandParameter="{Binding}"
                                                Background="#E0F2FE" Foreground="#0369A1" Margin="0,8,0,0" HorizontalAlignment="Right" />
                                    </StackPanel>
                                    
                                    <!-- ===================== RENDER MODE ===================== -->
                                    <Grid IsVisible="{Binding !IsEditing}">
                                        <md:MarkdownScrollViewer Markdown="{Binding SourceText}" Margin="0,0,40,0" />
                                        <Button Content="✎ Edit" 
                                                Command="{Binding EditCommand}" 
                                                Background="Transparent" Foreground="#94A3B8" 
                                                HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>
        
    </Grid>
    
</UserControl>
