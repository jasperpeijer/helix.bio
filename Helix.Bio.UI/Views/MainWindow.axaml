<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Helix.Bio.UI.ViewModels"
        x:Class="Helix.Bio.UI.Views.MainWindow"
        x:Name="RootWindow"
        x:CompileBindings="False"
        WindowState="Maximized"
        Title="Helix.Bio Studio" 
        Background="#FFFFFF" 
        FontFamily="Segoe UI, Inter, sans-serif">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PreviousTabCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="ToolTip">
            <Setter Property="MaxWidth" Value="2000"/>
        </Style>
        
        <Style Selector="TabControl.activityBar > TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,16"/>
            <Setter Property="Foreground" Value="#94A3B8"/> 
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        
        <Style Selector="TabControl.activityBar > TabItem:selected">
            <Setter Property="Foreground" Value="#2563EB"/> 
            <Setter Property="BorderBrush" Value="#2563EB"/> 
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>
        
        <Style Selector="TabControl.workspace">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid RowDefinitions="Auto,*">
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Hidden" 
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            ItemsPanel="{TemplateBinding ItemsPanel}" />
                        </ScrollViewer>
                        
                        <ContentPresenter Grid.Row="1"
                                          Name="PART_SelectedContentHost"
                                          Content="{TemplateBinding SelectedContent}"
                                          ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                          Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabControl.workspace > TabItem">
            <Setter Property="MinHeight" Value="32"/> 
            <Setter Property="FontSize" Value="12"/> 
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_LayoutRoot"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1,1,1,1"
                            Margin="0,0,-1,0"
                            ToolTip.Tip="{Binding TabToolTip}"
                            ToolTip.ShowDelay="400">
                        <Panel>
                            <Border Name="PART_TopHighlight" Height="2" VerticalAlignment="Top" Background="Transparent"/>
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              Margin="12,0,12,0" 
                                              VerticalAlignment="Center"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="TabControl.workspace > TabItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/> 
        </Style>
        
        <Style Selector="TabControl.workspace > TabItem:selected /template/ Border#PART_TopHighlight">
            <Setter Property="Background" Value="#3674FC"/>
        </Style>

        <Style Selector="Button.closeTab /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <Style Selector="Button.closeTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/> 
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="*, 200">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="60"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TabControl Grid.Row="0" Grid.Column="0" 
                    TabStripPlacement="Left" 
                    Classes="activityBar" 
                    Background="#F8FAFC"
                    Padding="0">
            
            <!-- Project explorer tab button -->
            <!-- TODO: Figure out how this works -->
            <TabItem>
                <TabItem.Header>
                    <Path Data="M10,4H4c-1.1,0-1.99,0.9-1.99,2L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8c0-1.1-0.9-2-2-2h-8L10,4z" 
                          Fill="{Binding $parent[TabItem].Foreground}" Width="20" Height="20" Stretch="Uniform"/>
                </TabItem.Header>
                
                <Border BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                    <ContentControl Content="{Binding Explorer}" />
                </Border>
            </TabItem>

            <!-- Tool explorer tab button -->
            <TabItem>
                <TabItem.Header>
                    <Path Data="M22.7,19l-9.1-9.1c0.9-2.3,0.4-5-1.5-6.9c-2-2-5-2.4-7.4-1.3L9,6L6,9L1.6,4.7C0.5,7.1,0.9,10.1,2.9,12.1 c1.9,1.9,4.6,2.4,6.9,1.5l9.1,9.1c0.4,0.4,1,0.4,1.4,0l2.3-2.3C23.1,20,23.1,19.4,22.7,19z" 
                          Fill="{Binding $parent[TabItem].Foreground}" Width="20" Height="20" Stretch="Uniform"/>
                </TabItem.Header>
                
                <!-- Sequence profile button -->
                <Border BorderBrush="#E2E8F0" BorderThickness="1,0,0,0" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="BIOINFORMATICS TOOLS" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                        <Button Content="Launch Sequence Profiler" 
                                Command="{Binding OpenNewSequenceProfilerCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="#FFFFFF" Foreground="#334155" 
                                BorderBrush="#CBD5E1" BorderThickness="1"
                                CornerRadius="4" Padding="12,8"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="0" Grid.Column="1" Background="#E2E8F0" ResizeDirection="Columns"/>

        <Border Grid.Row="0" Grid.Column="2" Background="#F8FAFC">
            <TabControl x:Name="WorkspaceTabControl"
                        ItemsSource="{Binding OpenTabs}" 
                        SelectedItem="{Binding ActiveTab}"
                        Classes="workspace"
                        Background="#FFFFFF"
                        Padding="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        PointerWheelChanged="WorkspaceTabs_PointerWheelChanged"
                        DragDrop.AllowDrop="True"
                        DragDrop.Drop="WorkspaceTabs_Drop"
                        DragDrop.DragOver="WorkspaceTabs_DragOver">
                
                <!-- TODO: Figure out what this does -->
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <!-- TODO: Figure out what this does -->
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch">
                            
                            <StackPanel Orientation="Horizontal" 
                                        Spacing="6" 
                                        PointerPressed="TabItem_PointerPressed">
                                
                                <ContentControl Content="{Binding}" ToolTip.Tip="TESTETST" ToolTip.ShowDelay="400">
                                    <ContentControl.DataTemplates>
                                        <DataTemplate DataType="vm:ToolWorkspaceTabViewModel">
                                            <Path Data="{StaticResource WrenchIcon}" Fill="#64748B" Width="13" Height="13" Stretch="Uniform"/>
                                        </DataTemplate>
                                        
                                        <DataTemplate DataType="vm:TextEditorViewModel">
                                            <Grid>
                                                <Path Data="{StaticResource HelixIcon}" 
                                                      Fill="#10B981"
                                                      Width="14" Height="14" Stretch="Uniform"
                                                      IsVisible="{Binding IsFasta}"/>
                                                <Path Data="{StaticResource FileIcon}" Fill="#94A3B8" Width="13" Height="13" Stretch="Uniform" IsVisible="{Binding IsDefaultFile}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.DataTemplates>
                                </ContentControl>

                                <TextBlock Text="{Binding TabTitle}" 
                                           Background="Transparent"
                                           ToolTip.Tip="{Binding TabTooltip}"
                                           ToolTip.Placement="Bottom"
                                           ToolTip.VerticalOffset="15"
                                           ToolTip.ShowDelay="100"
                                           MaxWidth="200"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" 
                                           Margin="0,0,4,0"/>
                                
                                <Button Classes="closeTab" 
                                        Command="{Binding #RootWindow.DataContext.CloseTabCommand}" 
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" Width="18" Height="18" Padding="0" CornerRadius="4">
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                          Fill="#94A3B8" Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" 
                Padding="20,12">
            <StackPanel Spacing="8">
                <TextBlock Text="TERMINAL" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                <TextBlock Text="> Core Engine initialized. UI Framework loaded." Foreground="#059669" FontFamily="Consolas, monospace" FontSize="12"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>