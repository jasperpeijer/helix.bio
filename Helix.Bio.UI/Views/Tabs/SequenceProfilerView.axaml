<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Helix.Bio.UI.ViewModels"
             x:Class="Helix.Bio.UI.Views.SequenceProfilerView"
             x:CompileBindings="False"
             x:DataType="vm:SequenceProfilerViewModel"
             Background="#F8FAFC">

    <Grid ColumnDefinitions="*, 380" Margin="16">
        
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,0">
            <Grid RowDefinitions="Auto, *">
                
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                    <TextBlock Grid.Column="0" Text="SEQUENCE DATA (RAW OR FASTA)" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Load from Disk..." Command="{Binding LoadFromFileCommand}" Background="#F1F5F9" Foreground="#334155" FontSize="12" Padding="10,6" CornerRadius="4"/>
                        <Button Content="Use Explorer Selection" Background="#F1F5F9" Foreground="#334155" FontSize="12" Padding="10,6" CornerRadius="4"/>
                    </StackPanel>
                </Grid>
                
                <TextBox Grid.Row="1" 
                         Text="{Binding InputSequence}"
                         AcceptsReturn="True" 
                         TextWrapping="Wrap"
                         FontFamily="Consolas, Courier New, monospace"
                         Background="#F8FAFC"
                         BorderBrush="#E2E8F0"
                         CornerRadius="4"
                         Padding="12"
                         Watermark="Paste DNA/RNA sequence or complete FASTA format here..."/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto, *">
            
            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel Spacing="12">
                    <Button Content="Run Full Profiling" 
                            Command="{Binding AnalyzeSequenceCommand}"
                            Background="#2563EB" Foreground="#FFFFFF" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            FontWeight="SemiBold" Padding="12" CornerRadius="4"/>
                    
                    <TextBlock Text="{Binding Warnings}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" IsVisible="{Binding Warnings, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="BIOCHEMICAL PROPERTIES" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                    
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" >
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Molecule Type" FontSize="11" Foreground="#94A3B8"/>
                            <TextBlock Text="{Binding SequenceType}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="Length" FontSize="11" Foreground="#94A3B8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding SequenceLength}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <TextBlock Text="bp" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="GC Content" FontSize="11" Foreground="#94A3B8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding GcContent, StringFormat='{}{0:F2}'}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <TextBlock Text="%" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="Melting Temp (Tm)" FontSize="11" Foreground="#94A3B8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding MeltingTemperature, StringFormat='{}{0:F2}'}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <TextBlock Text="°C" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Molecular Weight" FontSize="11" Foreground="#94A3B8"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding MolecularWeight, StringFormat='{}{0:F2}'}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <TextBlock Text="g/mol" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                        
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>