<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Helix.Bio.UI.ViewModels"
        x:Class="Helix.Bio.UI.Views.MainWindow"
        x:Name="RootWindow"
        x:CompileBindings="False"
        WindowState="Maximized"
        Title="Helix.Bio Studio" 
        Background="{DynamicResource BgPrimary}" 
        FontFamily="Inter, {StaticResource JetBrainsMonoFont}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PreviousTabCommand}" />
    </Window.KeyBindings>
    
    <DockPanel>
        
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Notebook" Command="{Binding NewNotebookCommand}"/>
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Project">
                <!-- This is where our Package Manager lives -->
                <MenuItem Header="_Package Manager" Command="{Binding OpenPackageManagerCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle Project Explorer"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About Helix.Bio"/>
            </MenuItem>
        </Menu>
        
        <Grid RowDefinitions="*, 200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="60"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TabControl Grid.Row="0" Grid.Column="0" 
                        TabStripPlacement="Left" 
                        Classes="activityBar" 
                        Background="{DynamicResource BgSecondary}"
                        Padding="0">
                
                <!-- Project explorer tab button -->
                <!-- TODO: Figure out how this works -->
                <TabItem>
                    <TabItem.Header>
                        <Path Data="M10,4H4c-1.1,0-1.99,0.9-1.99,2L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8c0-1.1-0.9-2-2-2h-8L10,4z" 
                              Fill="{Binding $parent[TabItem].Foreground}" Width="20" Height="20" Stretch="Uniform"/>
                    </TabItem.Header>
                    
                    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1,0,0,0">
                        <ContentControl Content="{Binding Explorer}" />
                    </Border>
                </TabItem>

                <!-- Tool explorer tab button -->
                <TabItem>
                    <TabItem.Header>
                        <Path Data="M22.7,19l-9.1-9.1c0.9-2.3,0.4-5-1.5-6.9c-2-2-5-2.4-7.4-1.3L9,6L6,9L1.6,4.7C0.5,7.1,0.9,10.1,2.9,12.1 c1.9,1.9,4.6,2.4,6.9,1.5l9.1,9.1c0.4,0.4,1,0.4,1.4,0l2.3-2.3C23.1,20,23.1,19.4,22.7,19z" 
                              Fill="{Binding $parent[TabItem].Foreground}" Width="20" Height="20" Stretch="Uniform"/>
                    </TabItem.Header>
                    
                    <!-- Sequence profile button -->
                    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1,0,0,0" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="BIOINFORMATICS TOOLS" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                            <Button Content="Launch Sequence Profiler" 
                                    Command="{Binding OpenNewSequenceProfilerCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Background="{DynamicResource BgPrimary}" Foreground="{DynamicResource TextPrimary}" 
                                    BorderBrush="{DynamicResource BorderDark}" BorderThickness="1"
                                    CornerRadius="4" Padding="12,8"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="0" Grid.Column="1" Background="{DynamicResource BorderDefault}" ResizeDirection="Columns"/>

            <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BgSecondary}">
                <TabControl x:Name="WorkspaceTabControl"
                            ItemsSource="{Binding OpenTabs}" 
                            SelectedItem="{Binding ActiveTab}"
                            Classes="workspace"
                            Background="{DynamicResource BgPrimary}"
                            Padding="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            PointerWheelChanged="WorkspaceTabs_PointerWheelChanged"
                            DragDrop.AllowDrop="True"
                            DragDrop.Drop="WorkspaceTabs_Drop"
                            DragDrop.DragOver="WorkspaceTabs_DragOver">
                    
                    <!-- TODO: Figure out what this does -->
                    <TabControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </TabControl.ItemsPanel>
                    
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" 
                                    HorizontalAlignment="Stretch" 
                                    VerticalAlignment="Stretch">
                                
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="6" 
                                            PointerPressed="TabItem_PointerPressed">
                                    
                                    <ContentControl Content="{Binding}" ToolTip.Tip="TESTETST" ToolTip.ShowDelay="400">
                                        <ContentControl.DataTemplates>
                                            <DataTemplate DataType="vm:JupyterWorkspaceTabViewModel">
                                                <!-- This replaces your previous <Path Data="{StaticResource JupyterIcon}" ... /> -->
                                                <Viewbox Width="14" Height="14" Stretch="Uniform" IsVisible="{Binding IsNotebook}">
        
                                                    <!-- The Canvas forces the invisible 24x24 grid to be respected -->
                                                    <Canvas Width="24" Height="24">
            
                                                        <Path Data="{StaticResource JupyterIcon}" 
                                                              Stroke="{DynamicResource IconJupyterColor}" 
                                                              StrokeThickness="2" 
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Fill="Transparent"/>
                  
                                                    </Canvas>
                                                </Viewbox>
                                            </DataTemplate>
                                            
                                            <DataTemplate DataType="vm:ToolWorkspaceTabViewModel">
                                                <Grid>
                                                    <Path Data="{StaticResource WrenchIcon}" Fill="{DynamicResource TextSecondary}" Width="13" Height="13" Stretch="Uniform"/>
                                                </Grid>
                                            </DataTemplate>
                                            
                                            <DataTemplate DataType="vm:TextEditorViewModel">
                                                <Grid>
                                                    <Path Data="{StaticResource HelixIcon}" 
                                                          Fill="{DynamicResource IconHelixColor}"
                                                          Width="14" Height="14" Stretch="Uniform"
                                                          IsVisible="{Binding IsFasta}"/>
                                                    <Path Data="{StaticResource FileIcon}" Fill="{DynamicResource TextMuted}" Width="13" Height="13" Stretch="Uniform" IsVisible="{Binding IsDefaultFile}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ContentControl.DataTemplates>
                                    </ContentControl>

                                    <TextBlock Text="{Binding TabTitle}" 
                                               Background="Transparent"
                                               ToolTip.Tip="{Binding TabTooltip}"
                                               ToolTip.Placement="Bottom"
                                               ToolTip.VerticalOffset="15"
                                               ToolTip.ShowDelay="100"
                                               MaxWidth="200"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" 
                                               Margin="0,0,4,0"/>
                                    
                                    <Button Classes="closeTab" 
                                            Command="{Binding #RootWindow.DataContext.CloseTabCommand}" 
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" Width="18" Height="18" Padding="0" CornerRadius="4">
                                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                              Fill="{DynamicResource TextMuted}" Width="10" Height="10" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                    Background="{DynamicResource BgPrimary}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,10,0,0" 
                    Padding="20,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="TERMINAL" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                    <TextBlock Text="> Core Engine initialized. UI Framework loaded." Foreground="{DynamicResource SuccessText}" FontFamily="{StaticResource JetBrainsMonoFont}" FontSize="12"/>
                </StackPanel>
            </Border>

        </Grid>
        
    </DockPanel>
</Window>