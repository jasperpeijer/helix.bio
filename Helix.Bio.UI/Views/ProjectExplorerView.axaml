<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Helix.Bio.UI.ViewModels"
             xmlns:conv="clr-namespace:Helix.Bio.UI.Converters"
             x:Class="Helix.Bio.UI.Views.ProjectExplorerView"
             x:CompileBindings="False"
             x:DataType="vm:ProjectExplorerViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <StackPanel Grid.Row="0" Spacing="4" Margin="20">
            <TextBlock Text="PROJECT EXPLORER" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding CurrentProjectPath}" Foreground="#2563EB" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>

        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding RootNodes}" 
                  Background="Transparent" 
                  Margin="10,0,10,20"
                  DoubleTapped="TreeView_DoubleTapped">
            
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.Styles>

            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                        
                        <Path Data="{StaticResource FolderIcon}" 
                              Fill="#D97706" Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsDirectory}"/>
                              
                        <Path Data="{StaticResource HelixIcon}" 
                              Fill="#10B981"
                              Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsFasta}"/>

                        <Path Data="{StaticResource FileIcon}" 
                              Fill="#94A3B8" Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsDefaultFile}"/>
                        
                        <TextBlock Text="{Binding Name}" Foreground="#334155" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        
    </Grid>
</UserControl>