<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Helix.Bio.UI.ViewModels"
             x:Class="Helix.Bio.UI.Views.ProjectExplorerView"
             x:CompileBindings="False"
             x:DataType="vm:ProjectExplorerViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <StackPanel Grid.Row="0" Spacing="4" Margin="20">
            <TextBlock Text="PROJECT EXPLORER" Foreground="#64748B" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding CurrentProjectPath}" Foreground="#2563EB" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>

        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding RootNodes}" 
                  Background="Transparent" 
                  Margin="10,0,10,20"
                  DoubleTapped="TreeView_DoubleTapped">
            
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.Styles>

            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                        
