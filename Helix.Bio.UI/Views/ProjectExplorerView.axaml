                              Fill="#10B981"
                              Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsFasta}"/>

                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8V4h5v5h5v11z" 
