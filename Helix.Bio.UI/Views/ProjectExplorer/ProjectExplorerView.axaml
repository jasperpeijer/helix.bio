<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Helix.Bio.UI.ViewModels"
             x:Class="Helix.Bio.UI.Views.ProjectExplorerView"
             x:CompileBindings="False"
             x:DataType="vm:ProjectExplorerViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <StackPanel Grid.Row="0" Spacing="4" Margin="20">
            <TextBlock Text="PROJECT EXPLORER" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
            <TextBlock Text="{Binding CurrentProjectPath}" Foreground="{DynamicResource AccentPrimary}" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>

        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding RootNodes}" 
                  Background="Transparent" 
                  Margin="10,0,10,20"
                  DoubleTapped="TreeView_DoubleTapped">
            
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.Styles>

            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                        
                        <Path Data="{StaticResource FolderIcon}" 
                              Fill="{DynamicResource IconFolderColor}" Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsDirectory}"/>
                              
                        <Path Data="{StaticResource HelixIcon}" 
                              Fill="{DynamicResource IconHelixColor}"
                              Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsFasta}"/>

                        <Path Data="{StaticResource FileIcon}" 
                              Fill="{DynamicResource TextMuted}" Width="14" Height="14" Stretch="Uniform"
                              IsVisible="{Binding IsDefaultFile}"/>
                        
                        <Viewbox Width="14" Height="14" Stretch="Uniform" IsVisible="{Binding IsNotebook}">
    
                            <!-- The Canvas forces the invisible 24x24 grid to be respected -->
                            <Canvas Width="28" Height="28">
        
                                <Path Data="{StaticResource JupyterIcon}" 
                                      Stroke="{DynamicResource IconJupyterColor}" 
                                      StrokeThickness="2" 
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Fill="Transparent"
                                      IsVisible="{Binding IsNotebook}"/>
              
                            </Canvas>
                        </Viewbox>
                        
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        
    </Grid>
</UserControl>